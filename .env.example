# LLM providers
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Turso DB — leave empty for local file:./data/content-bank.db
TURSO_URL=
TURSO_TOKEN=

# Storage backend — leave empty for local-fs.
# Drive on a personal @gmail account must use OAuth (service accounts have zero
# Drive storage quota). Obtain via:
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/cloud-platform,https://www.googleapis.com/auth/drive.file
# then read client_id/client_secret/refresh_token from application_default_credentials.json.
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_REFRESH_TOKEN=
# Project whose Drive API the request is billed to (x-goog-user-project).
GDRIVE_QUOTA_PROJECT=
GDRIVE_FOLDER_ID=
# Legacy service-account JSON (only works on Workspace Shared Drives).
GDRIVE_SA_JSON=

# YouTube data API (optional, for UP-channel monitoring)
YOUTUBE_API_KEY=
# Custom Search JSON API key (grounding for the scout)
SEARCH_API_KEY=

# Paths
CONTENT_BANK_DATA_DIR=./data
CONTENT_BANK_VIDEOS_DIR=./data/videos
